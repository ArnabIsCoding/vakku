rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /consequence_cache/{docId} {
      allow read:  if true;
      allow write: if false;
    }
    match /best_time_cache/{docId} {
      allow read:  if true;
      allow write: if false;
    }
    match /voter_trends_cache/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    match /rate_limits/{docId} {
      allow read:  if false;
      allow write: if false;
    }
    match /user_usage/{docId} {
      allow read:  if request.auth != null && docId.matches(request.auth.uid + '_.*');
      allow write: if false;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
